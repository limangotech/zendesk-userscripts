{
  "manifest_version": 3,
  "name": "Limango Zendesk Userscripts",
  "version": "0.3.0",
  "description": "Extends the Zendesk agent workspace with limango-specific automations, powered by the Limango 360 sidebar app.",
  "minimum_chrome_version": "111",
  "icons": {
    "16": "icons/icon-16.png",
    "32": "icons/icon-32.png",
    "48": "icons/icon-48.png",
    "128": "icons/icon-128.png"
  },
  "content_scripts": [
    {
      "matches": [
        "https://limango.zendesk.com/agent/*",
        "https://limango1779089774.zendesk.com/agent/*",
        "https://limango1778837136.zendesk.com/agent/*"
      ],
      "js": [
        "vendor/purify.min.js",
        "features/side-conversation-replacement.js"
      ],
      "run_at": "document_idle",
      "world": "MAIN"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "zendesk-userscripts-v1@limango.com",
      "strict_min_version": "142.0",
      "update_url": "https://github.com/limangotech/zendesk-userscripts/releases/latest/download/updates.json",
      "data_collection_permissions": {
        "required": [
          "none"
        ]
      }
    }
  }
}
